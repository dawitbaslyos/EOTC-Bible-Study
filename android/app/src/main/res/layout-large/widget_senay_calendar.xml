<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Month + day -->
    <TextView
        android:id="@+id/widget_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Meskerem 1"
        android:textColor="#D4AF37"
        android:textSize="18sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Saint / feast -->
    <TextView
        android:id="@+id/widget_saint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Three Saints"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Year name -->
    <TextView
        android:id="@+id/widget_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Year of St. John"
        android:textColor="#888888"
        android:textSize="11sp"
        android:layout_marginTop="2dp" />

    <!-- Streak -->
    <TextView
        android:id="@+id/widget_streak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#D4AF37"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

    <!-- Heatmap bars -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <ImageView
            android:id="@+id/widget_bar_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="#222222" />

        <ImageView
            android:id="@+id/widget_bar_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="#222222" />

        <ImageView
            android:id="@+id/widget_bar_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="#222222" />

        <ImageView
            android:id="@+id/widget_bar_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="#222222" />

        <ImageView
            android:id="@+id/widget_bar_5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="#222222" />

        <ImageView
            android:id="@+id/widget_bar_6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="#222222" />

        <ImageView
            android:id="@+id/widget_bar_7"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#222222" />
    </LinearLayout>

</LinearLayout>

