<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/app_lock_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F20A0A0C"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/app_lock_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_lock_overlay_title"
            android:textColor="#FFD4AF37"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/app_lock_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#E6FFFFFF"
            android:textSize="15sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:paddingBottom="28dp" />

        <Button
            android:id="@+id/app_lock_open_senay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_lock_open_senay"
            android:textAllCaps="false"
            android:paddingLeft="28dp"
            android:paddingRight="28dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp" />
    </LinearLayout>
</FrameLayout>
